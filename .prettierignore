#-------------------------------------------------------------------------------------------------------------------
# Prettier-specific overrides
#
# Everything in .gitignore is already excluded: prettier's default ignore path
# is both .gitignore and .prettierignore, and no script overrides --ignore-path.
#-------------------------------------------------------------------------------------------------------------------

# Package manager files
pnpm-lock.yaml
yarn.lock
package-lock.json
shrinkwrap.json

# Prettier re-formats code blocks inside Markdown, which affects rendered output
*.md

# Prettier re-formats comments in JSON, making the documentation hard to read.
**/tsconfig-base.json

#VSCode - ignore project level vscode settings
.vscode/

# Prettier re-formats handlebar templates, making the template hard to maintain.
*.hbs