{
  "name": "@apps/sveltekit-example-app",
  "version": "0.0.0",
  "private": true,
  "description": "SvelteKit Example App",
  "type": "module",
  "main": "build/index.js",
  "files": [
    "build"
  ],
  "scripts": {
