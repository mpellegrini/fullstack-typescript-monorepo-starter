{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "toolchain/typescript-config/**",
    "toolchain/eslint-config/**",
    "toolchain/vitest-config/**"
  ],
  "tasks": {
    "codegen": {
      "dependsOn": ["^codegen"]
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^codegen", "codegen"]
    },
    "test": {
      "dependsOn": ["^codegen", "codegen"],
      "outputs": ["./coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^codegen", "codegen"]
    }
  }
}
